# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here

# Optional: override default models
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# Supabase — Lead Capture database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Contentful — Headless CMS (Phase 5)
# Find these in Contentful dashboard → Settings → API keys
CONTENTFUL_SPACE_ID=your-space-id-here
CONTENTFUL_DELIVERY_API_KEY=your-delivery-api-key-here
CONTENTFUL_ENVIRONMENT=master
