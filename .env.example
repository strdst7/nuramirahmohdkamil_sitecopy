# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here

# Optional: override default models
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# Supabase — Lead Capture database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Contentful — Headless CMS (Phase 5)
# Find these in Contentful dashboard → Settings → API keys
CONTENTFUL_SPACE_ID=your-space-id-here
CONTENTFUL_DELIVERY_API_KEY=your-delivery-api-key-here
CONTENTFUL_ENVIRONMENT=master

# Email — Lead notification & newsletter (Phase 6)
# Primary: Resend (https://resend.com)
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_ADDRESS=notifications@yourdomain.com
NOTIFICATION_TO_ADDRESS=hello@nuramirah.com

# Fallback: SMTP (any provider — SendGrid, Gmail, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
